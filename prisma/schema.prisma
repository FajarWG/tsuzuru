datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  name          String?
  image         String?
  createdAt     DateTime          @default(now())
  accounts      Account[]
  transactions  Transaction[]
  templates     MonthlyTemplate[]
  settings      UserSettings?
  billFriends   BillFriend[]
  budgetLimits  BudgetLimit[]
}

model Account {
  id                      String        @id @default(cuid())
  userId                  String
  name                    String        // "Jago", "Yucho Bank", etc.
  currency                String        // "IDR" or "JPY"
  balance                 Float         @default(0)
  type                    String        // "bank", "ewallet", "investment"
  isActive                Boolean       @default(true)
  defaultPaymentAccountId String?
  isDefault               Boolean       @default(false)
  user                    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions            Transaction[]
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  accountId       String
  type            String   // "expense" | "income"
  amount          Float
  currency        String
  category        String   // "living_expenses" | "personal_spending" | "income" | "adjustment" (legacy: "pocket_money" | "shopping")
  subCategory     String?  // "food", "drinks", etc.
  mealNumber      Int?     // 1-4, only for food
  description     String?
  splitGroupId    String?  // Links split-bill adjustment transactions to their source transaction
  transferGroupId String?  // Links the two transactions involved in a transfer
  date            DateTime @default(now())
  isTemplate      Boolean  @default(false)
  isReceipt       Boolean  @default(false)
  receiptItems    Json?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model MonthlyTemplate {
  id             String  @id @default(cuid())
  userId         String
  name           String  // "Apato", "Listrik", etc.
  amount         Float
  currency       String
  accountId      String
  isActive       Boolean @default(true)
  intervalMonths Int     @default(1) // 1=monthly, 2=every 2 months, 3=quarterly, etc.
  paymentMode    String  @default("self_paid") // "self_paid" | "split_with_friends"
  splitConfig    Json?
  category       String  @default("living_expenses")
  subCategory    String  @default("utilities")
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id               String    @id @default(cuid())
  userId           String    @unique
  monthlyBudget    Float     @default(0)
  pocketMoneyLimit Float     @default(0)
  shoppingLimit    Float     @default(0)
  budgetCurrency   String    @default("JPY")
  isOnboarded      Boolean   @default(false)
  aiLimitUntil     DateTime? // AI rate-limit expiry, replaces filesystem-based tracking
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BillFriend {
  id          String    @id @default(cuid())
  userId      String
  personName  String    // Friend's name
  amount      Float
  currency    String    // "JPY" | "IDR"
  direction   String    // "i_owe" | "they_owe"
  description String?
  category    String?   // Original category (e.g. "pocket_money")
  subCategory String?   // Original subcategory (e.g. "food")
  isSettled   Boolean   @default(false)
  settledAt   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BudgetLimit {
  id            String   @id @default(cuid())
  userId        String
  name          String   // slug/unique name for category matching (e.g. "living_expenses")
  label         String   // display name (e.g. "Living Expenses")
  limit         Float
  subCategories Json?    // [{ value: string, label: string }]
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([userId, name])
}
