datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  name          String?
  image         String?
  createdAt     DateTime          @default(now())
  accounts      Account[]
  transactions  Transaction[]
  templates     MonthlyTemplate[]
  settings      UserSettings?
  billFriends   BillFriend[]
}

model Account {
  id           String        @id @default(cuid())
  userId       String
  name         String        // "Jago", "Yucho Bank", etc.
  currency     String        // "IDR" or "JPY"
  balance      Float         @default(0)
  type         String        // "bank", "ewallet", "investment"
  isActive     Boolean       @default(true)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  accountId   String
  type        String   // "expense" | "income"
  amount      Float
  currency    String
  category    String   // "pocket_money" | "shopping" | "income" | "template"
  subCategory String?  // "food", "drinks", etc.
  mealNumber  Int?     // 1-4, only for food
  description String?
  date        DateTime @default(now())
  isTemplate  Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model MonthlyTemplate {
  id             String  @id @default(cuid())
  userId         String
  name           String  // "Apato", "Listrik", etc.
  amount         Float
  currency       String
  accountId      String
  isActive       Boolean @default(true)
  intervalMonths Int     @default(1) // 1=monthly, 2=every 2 months, 3=quarterly, etc.
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id               String @id @default(cuid())
  userId           String @unique
  monthlyBudget    Float  @default(0)
  pocketMoneyLimit Float  @default(0)
  shoppingLimit    Float  @default(0)
  budgetCurrency   String @default("JPY")
  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BillFriend {
  id          String    @id @default(cuid())
  userId      String
  personName  String    // Friend's name
  amount      Float
  currency    String    // "JPY" | "IDR"
  direction   String    // "i_owe" | "they_owe"
  description String?
  isSettled   Boolean   @default(false)
  settledAt   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
